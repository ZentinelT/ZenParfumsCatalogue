{
  "name": "zen-parfums-catalogue",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fetch-catalog": "tsx scripts/fetch-catalog.ts",
    "fetch-catalog:fixture": "tsx scripts/fetch-catalog.ts --fixture",
    "dev": "nuxi dev",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "generate:fixture": "pnpm fetch-catalog:fixture && nuxi generate",
    "preview": "nuxi preview",
    "typecheck": "nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@nuxtjs/color-mode": "^3.5.2",
    "@pinia/nuxt": "^0.5.5",
    "nuxt": "^4.0.0",
    "pinia": "^2.2.6",
    "pinia-plugin-persistedstate": "^4.1.3",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.2",
    "@nuxt/test-utils": "^3.15.1",
    "@nuxtjs/sitemap": "^7.0.0",
    "@playwright/test": "^1.49.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "happy-dom": "^15.11.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
