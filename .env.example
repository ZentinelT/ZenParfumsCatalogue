# Clave de Supabase para el build (fetch-catalog). NO se expone al navegador.
# En CI vive en secrets.SUPABASE_KEY.
SUPABASE_KEY=

# Márgenes de precio (FR-007). Defaults: 15000 / 10000.
MARGEN_NORMAL=15000
MARGEN_TUBBEES=10000

# baseURL del sitio. '/' con dominio custom; '/ZenParfumsCatalogue/' para project page.
NUXT_APP_BASE_URL=/

# URL pública para sitemap/canonical (HU-3).
NUXT_SITE_URL=https://example.com
