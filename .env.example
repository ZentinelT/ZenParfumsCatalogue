# Clave de Supabase para el build (fetch-catalog). NO se expone al navegador.
# En CI vive en secrets.SUPABASE_KEY.
SUPABASE_KEY=

# Márgenes de precio (FR-007). Defaults: 15000 / 10000.
MARGEN_NORMAL=15000
MARGEN_TUBBEES=10000

# baseURL del sitio. '/' con dominio custom; '/ZenParfumsCatalogue/' para project page.
NUXT_APP_BASE_URL=/

# URL pública para sitemap/canonical (HU-3).
NUXT_SITE_URL=https://example.com

# --- Revalidación de stock/precio en runtime (FR-016) ---
# Anon key de Supabase: SÍ llega al navegador, por eso RLS debe limitarla a
# SELECT solo sobre la vista `catalogo_publico` (tarea T003).
# Si se deja vacía, la revalidación queda desactivada y el sitio usa los datos
# del build (degradación silenciosa).
NUXT_PUBLIC_SUPABASE_ANON_KEY=
NUXT_PUBLIC_CATALOGO_PUBLICO_TABLE=catalogo_publico
